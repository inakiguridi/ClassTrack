<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/" aria-label="Ir al dashboard"><img src="/logo-mark.svg" alt="" /><span>Class<span>Track</span></span></a>
      <nav class="nav">
        <a class="active" href="/">Dashboard</a>
        <a href="/students">Alumnos</a>
        <a href="/lessons">Clases</a>
        <a href="/payments">Pagos</a>
        <a href="/analytics">Analytics</a>
        <form class="logout-form" action="/logout" method="post">
          <button type="submit">Salir</button>
        </form>
      </nav>
    </header>

    <main class="container">
      <section class="page-header">
        <p class="eyebrow">V1</p>
        <h1><%= pageTitle %></h1>
        <p><%= subtitle %></p>
      </section>

      <%- include('partials/flash') %>

      <section class="summary-grid">
        <article class="summary-card">
          <span>Total cobrado</span>
          <strong>$<%= dashboard.totals.totalCharged.toLocaleString('es-CL') %></strong>
        </article>
        <article class="summary-card">
          <span>Total pagado</span>
          <strong>$<%= dashboard.totals.totalPaid.toLocaleString('es-CL') %></strong>
        </article>
        <article class="summary-card <%= dashboard.totals.balance > 0 ? 'summary-card-warning' : '' %>">
          <span>Total pendiente</span>
          <strong>$<%= dashboard.totals.balance.toLocaleString('es-CL') %></strong>
        </article>
      </section>

      <section class="panel">
        <h2>Este mes</h2>
        <div class="summary-grid compact-summary">
          <article class="summary-card">
            <span>Cobrado</span>
            <strong>$<%= currentMonth.totalCharged.toLocaleString('es-CL') %></strong>
          </article>
          <article class="summary-card">
            <span>Pagado</span>
            <strong>$<%= currentMonth.totalPaid.toLocaleString('es-CL') %></strong>
          </article>
          <article class="summary-card <%= currentMonth.balance > 0 ? 'summary-card-warning' : '' %>">
            <span>Pendiente</span>
            <strong>$<%= currentMonth.balance.toLocaleString('es-CL') %></strong>
          </article>
        </div>
      </section>

      <section class="panel">
        <h2>Acciones</h2>
        <a class="button-link" href="/students">Ir a alumnos</a>
        <a class="button-link button-link-secondary" href="/lessons">Ir a clases</a>
        <a class="button-link button-link-secondary" href="/payments">Ir a pagos</a>
      </section>

      <section class="panel">
        <h2>Exportar CSV</h2>
        <div class="form-actions">
          <a class="button-link" href="/export/students.csv">Alumnos</a>
          <a class="button-link button-link-secondary" href="/export/lessons.csv">Clases</a>
          <a class="button-link button-link-secondary" href="/export/payments.csv">Pagos</a>
        </div>
      </section>

      <section class="list-section">
        <h2>Ultimos movimientos</h2>
        <% if (recentActivity.length === 0) { %>
          <p class="empty">Aun no hay movimientos registrados.</p>
        <% } else { %>
          <div class="student-grid">
            <% recentActivity.forEach((activity) => { %>
              <article class="student-card">
                <div>
                  <h3>
                    <a href="<%= activity.type === 'lesson' ? `/lessons/${activity.id}/edit` : `/payments/${activity.id}/edit` %>">
                      <%= activity.type === 'lesson' ? 'Clase' : 'Pago' %> - <%= activity.studentName %>
                    </a>
                  </h3>
                  <p><%= activity.activityDate %> - <%= activity.detail %></p>
                </div>
                <strong>$<%= activity.amount.toLocaleString('es-CL') %></strong>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>

      <section class="list-section">
        <h2>Saldos por alumno</h2>

        <% if (dashboard.students.length === 0) { %>
          <p class="empty">Aun no hay alumnos registrados.</p>
        <% } else { %>
          <div class="student-grid">
            <% dashboard.students.forEach((student) => { %>
              <article class="student-card">
                <div>
                  <h3><a href="/students/<%= student.id %>"><%= student.name %></a></h3>
                  <p>
                    Clases: $<%= student.totalCharged.toLocaleString('es-CL') %>
                    - Pagos: $<%= student.totalPaid.toLocaleString('es-CL') %>
                  </p>
                </div>
                <strong class="<%= student.balance > 0 ? 'balance-due' : 'balance-ok' %>">
                  $<%= student.balance.toLocaleString('es-CL') %>
                </strong>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>

      <section class="list-section">
        <h2>Resumen mensual</h2>

        <% if (monthlySummary.length === 0) { %>
          <p class="empty">Aun no hay movimientos mensuales.</p>
        <% } else { %>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Mes</th>
                  <th>Cobrado</th>
                  <th>Pagado</th>
                  <th>Pendiente</th>
                </tr>
              </thead>
              <tbody>
                <% monthlySummary.forEach((month) => { %>
                  <tr>
                    <td><%= month.month %></td>
                    <td>$<%= month.totalCharged.toLocaleString('es-CL') %></td>
                    <td>$<%= month.totalPaid.toLocaleString('es-CL') %></td>
                    <td>$<%= month.balance.toLocaleString('es-CL') %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </main>
  </body>
</html>
