<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | ClassTrack</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/" aria-label="Ir al dashboard"><img src="/logo-mark.svg" alt="" /><span>Class<span>Track</span></span></a>
      <nav class="nav">
        <a href="/">Dashboard</a>
        <a class="active" href="/students">Alumnos</a>
        <a href="/lessons">Clases</a>
        <a href="/payments">Pagos</a>
        <form class="logout-form" action="/logout" method="post">
          <button type="submit">Salir</button>
        </form>
      </nav>
    </header>

    <main class="container">
      <section class="page-header">
        <p class="eyebrow">V1</p>
        <h1>Alumnos</h1>
        <p>Registra la tarifa por hora de cada alumno para calcular cobros por sesion.</p>
      </section>

      <%- include('../partials/flash') %>

      <% if (errors.length > 0) { %>
        <section class="alert">
          <% errors.forEach((error) => { %>
            <p><%= error %></p>
          <% }) %>
        </section>
      <% } %>

      <section class="list-section">
        <h2>Listado</h2>

        <% if (students.length === 0) { %>
          <p class="empty">Aun no hay alumnos registrados.</p>
        <% } else { %>
          <div class="student-grid">
            <% students.forEach((student) => { %>
              <article class="student-card">
                <div>
                  <h3><a href="/students/<%= student.id %>"><%= student.name %></a></h3>
                  <p><%= student.parentName ? `Padre: ${student.parentName}` : 'Sin nombre de padre' %></p>
                </div>
                <strong>$<%= student.hourlyRate.toLocaleString('es-CL') %>/h</strong>
                <% if (student.notes) { %>
                  <p class="notes"><%= student.notes %></p>
                <% } %>
                <div class="card-actions">
                  <a href="/students/<%= student.id %>">Ver</a>
                  <a href="/students/<%= student.id %>/edit">Editar</a>
                  <form action="/students/<%= student.id %>/delete" method="post" data-confirm="Esto borrara el alumno y sus clases/pagos asociados.">
                    <button class="danger-button" type="submit">Eliminar</button>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>

      <details class="panel add-panel" <%= errors.length > 0 ? 'open' : '' %>>
        <summary>Agregar alumno nuevo</summary>
        <form class="form" action="/students" method="post">
          <label>
            Nombre
            <input name="name" type="text" value="<%= formData.name || '' %>" required />
          </label>

          <label>
            Nombre padre
            <input name="parentName" type="text" maxlength="120" value="<%= formData.parentName || '' %>" />
          </label>

          <label>
            Tarifa por hora (CLP)
            <input
              name="hourlyRate"
              type="number"
              min="0"
              step="1"
              value="<%= formData.hourlyRate || '' %>"
              required
            />
          </label>

          <label>
            Notas
            <textarea name="notes" rows="3"><%= formData.notes || '' %></textarea>
          </label>

          <button type="submit">Guardar alumno</button>
        </form>
      </details>
    </main>

    <script src="/confirm.js"></script>
  </body>
</html>
