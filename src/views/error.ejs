<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | ClassTrack</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/" aria-label="Ir al dashboard"><img src="/logo-mark.svg" alt="" /><span>Class<span>Track</span></span></a>
      <nav class="nav">
        <a href="/">Dashboard</a>
        <a href="/students">Alumnos</a>
        <a href="/lessons">Clases</a>
        <a href="/payments">Pagos</a>
        <a href="/analytics">Analytics</a>
        <form class="logout-form" action="/logout" method="post">
          <button type="submit">Salir</button>
        </form>
      </nav>
    </header>

    <main class="container">
      <section class="alert">
        <p><%= message %></p>
      </section>
    </main>
  </body>
</html>
