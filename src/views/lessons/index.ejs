<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | ClassTrack</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/" aria-label="Ir al dashboard"><img src="/logo-mark.svg" alt="" /><span>Class<span>Track</span></span></a>
      <nav class="nav">
        <a href="/">Dashboard</a>
        <a href="/students">Alumnos</a>
        <a class="active" href="/lessons">Clases</a>
        <a href="/payments">Pagos</a>
        <a href="/analytics">Analytics</a>
        <form class="logout-form" action="/logout" method="post">
          <button type="submit">Salir</button>
        </form>
      </nav>
    </header>

    <main class="container">
      <section class="page-header">
        <p class="eyebrow">V1</p>
        <h1>Clases</h1>
        <p>Registra sesiones realizadas y guarda el cobro final en CLP.</p>
      </section>

      <%- include('../partials/flash') %>

      <% if (errors.length > 0) { %>
        <section class="alert">
          <% errors.forEach((error) => { %>
            <p><%= error %></p>
          <% }) %>
        </section>
      <% } %>

      <section class="panel">
        <h2>Nueva clase</h2>

        <% if (students.length === 0) { %>
          <p class="empty">Primero crea al menos un alumno.</p>
          <a class="button-link" href="/students">Ir a alumnos</a>
        <% } else { %>
          <form class="form" action="/lessons" method="post" data-lesson-form>
            <input type="hidden" name="filterStudentId" value="<%= filters.studentId || '' %>" />
            <input type="hidden" name="filterDateFrom" value="<%= filters.dateFrom || '' %>" />
            <input type="hidden" name="filterDateTo" value="<%= filters.dateTo || '' %>" />
            <label>
              Alumno
              <select name="studentId" required data-student-select>
                <option value="">Seleccionar alumno</option>
                <% students.forEach((student) => { %>
                  <option
                    value="<%= student.id %>"
                    data-rate="<%= student.hourlyRate %>"
                    <%= Number(formData.studentId) === Number(student.id) ? 'selected' : '' %>
                  >
                    <%= student.name %> - $<%= student.hourlyRate.toLocaleString('es-CL') %>/h
                  </option>
                <% }) %>
              </select>
            </label>

            <label>
              Fecha
              <input name="lessonDate" type="date" value="<%= formData.lessonDate %>" required />
            </label>

            <label>
              Duracion
              <select name="durationPreset" data-duration-preset>
                <option value="60" <%= Number(formData.durationMinutes) === 60 ? 'selected' : '' %>>60 min</option>
                <option value="90" <%= Number(formData.durationMinutes) === 90 ? 'selected' : '' %>>90 min</option>
                <option value="other" <%= ![60, 90].includes(Number(formData.durationMinutes)) ? 'selected' : '' %>>Otro</option>
              </select>
            </label>

            <label data-duration-custom-wrapper>
              Duracion manual (minutos)
              <input
                name="durationMinutes"
                type="number"
                min="1"
                max="480"
                step="1"
                value="<%= formData.durationMinutes || 60 %>"
                required
                data-duration-input
              />
            </label>

            <fieldset class="fieldset">
              <legend>Modo de cobro</legend>
              <label class="radio-row">
                <input
                  name="chargeMode"
                  type="radio"
                  value="auto"
                  <%= formData.chargeMode !== 'manual' ? 'checked' : '' %>
                  data-charge-mode
                />
                Automatico por tarifa
              </label>
              <label class="radio-row">
                <input
                  name="chargeMode"
                  type="radio"
                  value="manual"
                  <%= formData.chargeMode === 'manual' ? 'checked' : '' %>
                  data-charge-mode
                />
                Monto manual
              </label>
            </fieldset>

            <label data-manual-amount-wrapper>
              Monto manual (CLP)
              <input
                name="manualAmount"
                type="number"
                min="0"
                step="1"
                value="<%= formData.manualAmount || '' %>"
                data-manual-amount-input
              />
            </label>

            <p class="preview" data-amount-preview>Total estimado: $0</p>

            <label>
              Notas
              <textarea name="notes" rows="3"><%= formData.notes || '' %></textarea>
            </label>

            <button type="submit">Guardar clase</button>
          </form>
        <% } %>
      </section>

      <section class="list-section">
        <h2>Clases registradas</h2>

        <form class="filter-form" action="/lessons" method="get">
          <label>
            Alumno
            <select name="studentId">
              <option value="">Todos</option>
              <% students.forEach((student) => { %>
                <option value="<%= student.id %>" <%= Number(filters.studentId) === Number(student.id) ? 'selected' : '' %>>
                  <%= student.name %>
                </option>
              <% }) %>
            </select>
          </label>
          <label>
            Desde
            <input name="dateFrom" type="date" value="<%= filters.dateFrom || '' %>" />
          </label>
          <label>
            Hasta
            <input name="dateTo" type="date" value="<%= filters.dateTo || '' %>" />
          </label>
          <div class="filter-actions">
            <button type="submit">Filtrar</button>
            <a class="button-link button-link-secondary" href="/lessons">Limpiar</a>
          </div>
        </form>

        <% if (lessons.length === 0) { %>
          <p class="empty">Aun no hay clases registradas.</p>
        <% } else { %>
          <div class="student-grid">
            <% lessons.forEach((lesson) => { %>
              <article class="student-card">
                <div>
                  <h3><%= lesson.studentName %></h3>
                  <p><%= lesson.lessonDate %> - <%= lesson.durationMinutes %> min</p>
                </div>
                <strong>$<%= lesson.amountCharged.toLocaleString('es-CL') %></strong>
                <p class="notes">
                  <%= lesson.chargeMode === 'manual' ? 'Manual' : 'Automatico' %>
                  a $<%= lesson.hourlyRateSnapshot.toLocaleString('es-CL') %>/h
                </p>
                <% if (lesson.notes) { %>
                  <p class="notes"><%= lesson.notes %></p>
                <% } %>
                <div class="card-actions">
                  <a href="/lessons/<%= lesson.id %>/edit">Editar</a>
                  <form action="/lessons/<%= lesson.id %>/delete" method="post" data-confirm="Esto eliminara la clase registrada.">
                    <button class="danger-button" type="submit">Eliminar</button>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    </main>

    <script src="/lessons.js"></script>
    <script src="/confirm.js"></script>
  </body>
</html>
